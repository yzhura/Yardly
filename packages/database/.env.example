# Prisma CLI loads this `.env` automatically.
# Put DATABASE_URL here for `npm run db:*`, or export it in the shell.
#
# Supabase → Settings → Database → Connection string (URI), direct (5432).
# Keep the same URL as in apps/api for the same environment (dev Supabase project).

DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?schema=public"
