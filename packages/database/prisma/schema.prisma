generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationRole {
  OWNER
  ADMIN
  MANAGER
  SHIPPER
}

enum MembershipStatus {
  ACTIVE
  DEACTIVATED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  CANCELLED
}

enum IntegrationProvider {
  NOVA_POSHTA
  CHECKBOX
}

enum IntegrationSecretKey {
  NOVA_POSHTA_API_KEY
  CHECKBOX_LICENCE_KEY
  CHECKBOX_TEST_LICENCE_KEY
  CHECKBOX_PINCODE
  CHECKOX_TEST_PINCODE
}

enum AttributeScope {
  MATERIAL
  PRODUCT
  BOTH
}

enum ProductStatus {
  DRAFT
  ACTIVE
}

/// Application user linked to Supabase Auth (`auth.users.id`).
model User {
  id         String   @id @default(cuid())
  authUserId String   @unique @map("auth_user_id")
  email      String?
  firstName  String?  @map("first_name")
  lastName   String?  @map("last_name")
  /// User-uploaded avatar: HTTPS URL (legacy) or Storage object path (`avatars/{userId}/…`); UI usually resolves to public or signed Supabase URL.
  avatarUrl       String? @map("avatar_url")
  /// Preset id (`avatar_1`…`avatar_18`) for public Storage objects under `presets/avatars/`.
  avatarPresetId  String? @map("avatar_preset_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  memberships      Membership[]
  invitationsSent  Invitation[] @relation("InvitationInvitedBy")

  @@map("users")
}

/// Root tenant (organization). Business data should reference tenantId.
model Tenant {
  id                     String           @id @default(cuid())
  name                   String
  /// Company logo reference: HTTPS URL (legacy) or Storage object path (`logos/{tenantId}/...`).
  logoUrl                String?          @map("logo_url")
  activeBusinessProfileId String?         @unique @map("active_business_profile_id")
  createdAt              DateTime         @default(now()) @map("created_at")
  updatedAt              DateTime         @updatedAt @map("updated_at")

  memberships          Membership[]
  invitations          Invitation[]
  businessProfiles     BusinessProfile[] @relation("TenantBusinessProfiles")
  activeBusinessProfile BusinessProfile? @relation("TenantActiveBusinessProfile", fields: [activeBusinessProfileId], references: [id], onDelete: SetNull)

  materialCategories   MaterialCategory[]
  materials            Material[]
  colors               Color[]
  attributeDefinitions AttributeDefinition[]
  attributeValues      AttributeValue[]
  products             Product[]
  productVariants      ProductVariant[]
  catalogs             Catalog[]

  @@map("tenants")
}

/// Membership of a user in a tenant with a role (one row per user per tenant).
model Membership {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  tenantId  String           @map("tenant_id")
  role      OrganizationRole
  status    MembershipStatus @default(ACTIVE)
  /// Lowercase unique handle within the tenant for @mentions (always set; auto-assigned on join).
  handle    String
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@unique([tenantId, handle])
  @@map("memberships")
}

/// Pending or completed invite to join a tenant (email + role). Email is stored normalized (lowercase).
model Invitation {
  id          String           @id @default(cuid())
  email       String
  tenantId    String           @map("tenant_id")
  role        OrganizationRole
  status      InvitationStatus @default(PENDING)
  invitedById String           @map("invited_by_id")
  expiresAt   DateTime         @map("expires_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy User   @relation("InvitationInvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([tenantId])
  @@map("invitations")
}

/// Business profile (e.g. FOP legal entity) used for logistics/payment integrations.
model BusinessProfile {
  id                 String                  @id @default(cuid())
  tenantId           String                  @map("tenant_id")
  displayName        String                  @map("display_name")
  legalName          String?                 @map("legal_name")
  taxId              String?                 @map("tax_id")
  registrationNumber String?                 @map("registration_number")
  createdAt          DateTime                @default(now()) @map("created_at")
  updatedAt          DateTime                @updatedAt @map("updated_at")

  tenant        Tenant                   @relation("TenantBusinessProfiles", fields: [tenantId], references: [id], onDelete: Cascade)
  activeForTenant Tenant?                @relation("TenantActiveBusinessProfile")
  credentials   IntegrationCredential[]

  @@index([tenantId])
  @@map("business_profiles")
}

/// Encrypted integration secret for one provider under a business profile.
model IntegrationCredential {
  id                String              @id @default(cuid())
  businessProfileId String              @map("business_profile_id")
  provider          IntegrationProvider
  keyName           IntegrationSecretKey @map("key_name")
  encryptedValue    String              @map("encrypted_value")
  iv                String              @map("iv")
  authTag           String              @map("auth_tag")
  keyVersion        Int                 @default(1) @map("key_version")
  maskedValue       String              @map("masked_value")
  label             String?             @map("label")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  businessProfile BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@unique([businessProfileId, provider, keyName])
  @@index([provider])
  @@map("integration_credentials")
}

/// Category of materials within a tenant (e.g. fabric, trims).
model MaterialCategory {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  name       String
  isArchived Boolean  @default(false) @map("is_archived")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  materials Material[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("material_categories")
}

/// Brand color / swatch stored as a tenant-scoped master data.
model Color {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  name       String
  slug       String   @map("slug")
  hex        String   @map("hex")
  isArchived Boolean  @default(false) @map("is_archived")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  materials Material[]

  @@unique([tenantId, slug])
  @@unique([tenantId, hex])
  @@index([tenantId])
  @@map("colors")
}

/// Inventory material tracked by quantity + reserved amount.
model Material {
  id              String            @id @default(cuid())
  tenantId        String            @map("tenant_id")
  categoryId      String            @map("category_id")
  name            String
  sku             String
  colorId         String?           @map("color_id")
  unit            String            @map("unit")
  imagePath       String?           @map("image_path")
  quantityTotal   Float             @default(0) @map("quantity_total")
  quantityReserved Float            @default(0) @map("quantity_reserved")
  minStock        Float             @default(0) @map("min_stock")
  isArchived      Boolean           @default(false) @map("is_archived")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category MaterialCategory  @relation(fields: [categoryId], references: [id])
  color    Color?            @relation(fields: [colorId], references: [id])

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([categoryId])
  @@map("materials")
}

/// Configurable tenant-level attribute definition (e.g. size, cup size).
model AttributeDefinition {
  id         String         @id @default(cuid())
  tenantId   String         @map("tenant_id")
  name       String
  slug       String         @map("slug")
  scope      AttributeScope @default(BOTH)
  isSystem   Boolean        @default(false) @map("is_system")
  isArchived Boolean        @default(false) @map("is_archived")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  values AttributeValue[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("attribute_definitions")
}

/// Allowed value for tenant attribute definition.
model AttributeValue {
  id                   String   @id @default(cuid())
  tenantId             String   @map("tenant_id")
  attributeDefinitionId String   @map("attribute_definition_id")
  name                 String
  slug                 String   @map("slug")
  sortIndex            Int      @default(0) @map("sort_index")
  isArchived           Boolean  @default(false) @map("is_archived")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  attributeDefinition AttributeDefinition @relation(fields: [attributeDefinitionId], references: [id], onDelete: Cascade)

  @@unique([attributeDefinitionId, slug])
  @@index([tenantId])
  @@index([attributeDefinitionId])
  productVariantLinks ProductVariantAttributeValue[]

  @@map("attribute_values")
}

/// Sellable product (style / parent) scoped to a tenant.
model Product {
  id          String        @id @default(cuid())
  tenantId    String        @map("tenant_id")
  name        String
  description String?       @db.Text
  /// Storage object paths within tenant prefix (e.g. `products/{tenantId}/…`); private bucket + signed read URLs in API.
  imagePaths  String[]      @default([]) @map("image_paths")
  status      ProductStatus @default(DRAFT)
  isArchived  Boolean       @default(false) @map("is_archived")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  variants          ProductVariant[]
  catalogProducts CatalogProduct[]

  @@index([tenantId])
  @@map("products")
}

/// Curated product grouping within a tenant (line, season, channel list).
model Catalog {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String
  slug        String   @map("slug")
  description String?  @db.Text
  sortIndex   Int      @default(0) @map("sort_index")
  isArchived  Boolean  @default(false) @map("is_archived")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  catalogProducts CatalogProduct[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("catalogs")
}

/// Many-to-many: product appears in one or more catalogs (required for active merchandising).
model CatalogProduct {
  catalogId String @map("catalog_id")
  productId String @map("product_id")
  sortIndex Int    @default(0) @map("sort_index")

  catalog Catalog @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([catalogId, productId])
  @@index([productId])
  @@index([catalogId])
  @@map("catalog_products")
}

/// SKU-level sellable unit; integrations and orders should target this row.
model ProductVariant {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  productId      String   @map("product_id")
  sku            String
  name           String?
  /// Gallery paths in tenant storage (`vd/…` before save, `v/{variantId}/…` after); signed URLs from API.
  imagePaths     String[] @default([]) @map("image_paths")
  price          Decimal  @default(0) @db.Decimal(12, 2)
  compareAtPrice Decimal? @map("compare_at_price") @db.Decimal(12, 2)
  cost           Decimal? @db.Decimal(12, 2)
  sortIndex      Int      @default(0) @map("sort_index")
  isArchived     Boolean  @default(false) @map("is_archived")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant            Tenant                         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product           Product                        @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributeBindings ProductVariantAttributeValue[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([productId])
  @@map("product_variants")
}

/// Selected tenant attribute values for a variant (e.g. size + color options).
model ProductVariantAttributeValue {
  variantId        String @map("variant_id")
  attributeValueId String @map("attribute_value_id")

  variant        ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attributeValue AttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@id([variantId, attributeValueId])
  @@index([attributeValueId])
  @@map("product_variant_attribute_values")
}
