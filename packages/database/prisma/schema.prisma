generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationRole {
  OWNER
  ADMIN
  MANAGER
  SHIPPER
}

enum MembershipStatus {
  ACTIVE
  DEACTIVATED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  CANCELLED
}

enum IntegrationProvider {
  NOVA_POSHTA
  CHECKBOX
}

enum IntegrationSecretKey {
  NOVA_POSHTA_API_KEY
  CHECKBOX_LICENCE_KEY
  CHECKBOX_TEST_LICENCE_KEY
  CHECKBOX_PINCODE
  CHECKOX_TEST_PINCODE
}

/// Application user linked to Supabase Auth (`auth.users.id`).
model User {
  id         String   @id @default(cuid())
  authUserId String   @unique @map("auth_user_id")
  email      String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  memberships      Membership[]
  invitationsSent  Invitation[] @relation("InvitationInvitedBy")

  @@map("users")
}

/// Root tenant (organization). Business data should reference tenantId.
model Tenant {
  id                     String           @id @default(cuid())
  name                   String
  activeBusinessProfileId String?         @unique @map("active_business_profile_id")
  createdAt              DateTime         @default(now()) @map("created_at")
  updatedAt              DateTime         @updatedAt @map("updated_at")

  memberships          Membership[]
  invitations          Invitation[]
  businessProfiles     BusinessProfile[] @relation("TenantBusinessProfiles")
  activeBusinessProfile BusinessProfile? @relation("TenantActiveBusinessProfile", fields: [activeBusinessProfileId], references: [id], onDelete: SetNull)

  @@map("tenants")
}

/// Membership of a user in a tenant with a role (one row per user per tenant).
model Membership {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  tenantId  String           @map("tenant_id")
  role      OrganizationRole
  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@map("memberships")
}

/// Pending or completed invite to join a tenant (email + role). Email is stored normalized (lowercase).
model Invitation {
  id          String           @id @default(cuid())
  email       String
  tenantId    String           @map("tenant_id")
  role        OrganizationRole
  status      InvitationStatus @default(PENDING)
  invitedById String           @map("invited_by_id")
  expiresAt   DateTime         @map("expires_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy User   @relation("InvitationInvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([tenantId])
  @@map("invitations")
}

/// Business profile (e.g. FOP legal entity) used for logistics/payment integrations.
model BusinessProfile {
  id                 String                  @id @default(cuid())
  tenantId           String                  @map("tenant_id")
  displayName        String                  @map("display_name")
  legalName          String?                 @map("legal_name")
  taxId              String?                 @map("tax_id")
  registrationNumber String?                 @map("registration_number")
  createdAt          DateTime                @default(now()) @map("created_at")
  updatedAt          DateTime                @updatedAt @map("updated_at")

  tenant        Tenant                   @relation("TenantBusinessProfiles", fields: [tenantId], references: [id], onDelete: Cascade)
  activeForTenant Tenant?                @relation("TenantActiveBusinessProfile")
  credentials   IntegrationCredential[]

  @@index([tenantId])
  @@map("business_profiles")
}

/// Encrypted integration secret for one provider under a business profile.
model IntegrationCredential {
  id                String              @id @default(cuid())
  businessProfileId String              @map("business_profile_id")
  provider          IntegrationProvider
  keyName           IntegrationSecretKey @map("key_name")
  encryptedValue    String              @map("encrypted_value")
  iv                String              @map("iv")
  authTag           String              @map("auth_tag")
  keyVersion        Int                 @default(1) @map("key_version")
  maskedValue       String              @map("masked_value")
  label             String?             @map("label")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  businessProfile BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@unique([businessProfileId, provider, keyName])
  @@index([provider])
  @@map("integration_credentials")
}
