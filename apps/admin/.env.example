# Backend base URL (admin → Nest API)
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Supabase Auth / client (use the anon key only; never service_role here)
# NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Preset avatars in Storage (public): object path `{prefix}avatar_N.webp` inside `{bucket}`
# NEXT_PUBLIC_SUPABASE_PRESET_AVATAR_BUCKET="presets"
# NEXT_PUBLIC_SUPABASE_PRESET_AVATAR_PREFIX="avatars"
