PORT=3001

# Same Postgres as Supabase project (direct connection recommended for migrations
# if you run Prisma from this machine; runtime can use the same URL to start).

DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?schema=public"

# JWT validation for /auth/me and /tenants/setup (use anon key, not service_role)
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"

# Server-only: invite emails (auth.admin.inviteUserByEmail). Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# CORS for the admin app (comma-separated origins in production if needed)
ADMIN_ORIGIN="http://localhost:3000"

# 32-byte key for AES-256-GCM encryption of integration secrets (base64 or raw 32-char string)
INTEGRATION_SECRETS_MASTER_KEY="replace-with-32-byte-secret"
