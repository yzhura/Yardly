PORT=3001

# Same Postgres as Supabase project (direct connection recommended for migrations
# if you run Prisma from this machine; runtime can use the same URL to start).

DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?schema=public"

# JWT validation for /auth/me and /tenants/setup (use anon key, not service_role)
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"

# Server-only: invite emails (auth.admin.inviteUserByEmail). Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# User-uploaded avatars (bucket `users`, path `avatars/{userId}/…`): signed upload from API.
SUPABASE_USER_AVATAR_BUCKET="users"
# Path prefix inside that bucket before `{userId}/{filename}` (no slashes at ends).
SUPABASE_USER_AVATAR_PREFIX="avatars"
# `true` (default): resolve avatars as stable public URLs (`/object/public/...`) so other users
# can load them in the UI — enable public read on this path in Supabase Storage.
# `false`: use signed read URLs instead (private bucket; URLs expire — use SIGNED_READ_TTL).
SUPABASE_USER_AVATAR_PUBLIC_READ="true"
# Signed read URL lifetime in seconds (only when SUPABASE_USER_AVATAR_PUBLIC_READ=false).
SUPABASE_USER_AVATAR_SIGNED_READ_TTL_SEC="3600"

# Tenant/company logo path in Storage (`logos/{tenantId}/...`).
SUPABASE_TENANT_LOGO_BUCKET="users"
SUPABASE_TENANT_LOGO_PREFIX="logos"
# `true` (default): resolve logos as public URLs.
SUPABASE_TENANT_LOGO_PUBLIC_READ="true"
# Signed read URL lifetime in seconds (used when PUBLIC_READ=false).
SUPABASE_TENANT_LOGO_SIGNED_READ_TTL_SEC="3600"

# Built-in preset avatars: public URLs under `object/public/{bucket}/{prefix}/avatar_N.webp`
SUPABASE_PRESET_AVATAR_BUCKET="presets"
SUPABASE_PRESET_AVATAR_PREFIX="avatars"

# CORS for the admin app (comma-separated origins in production if needed)
ADMIN_ORIGIN="http://localhost:3000"

# 32-byte key for AES-256-GCM encryption of integration secrets (base64 or raw 32-char string)
INTEGRATION_SECRETS_MASTER_KEY="replace-with-32-byte-secret"
