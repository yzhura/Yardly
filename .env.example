# =============================================================================
# Yardly — environment template (copy values into apps/* and packages/* .env)
# =============================================================================
#
# Copy secrets into each app/package `.env` (gitignored). Prisma CLI reads
# `packages/database/.env`; Nest reads `apps/api/.env`.
#
# Supabase: use one cloud project per environment (strongly recommended):
#   - production  → separate project, strict keys, backups enabled
#   - development → separate project (shared by the team) OR local Supabase CLI
#
# Why two (or more) projects?
#   - Prod data stays isolated; you can reset / branch schema on dev without risk.
#   - Different API keys and database passwords per environment.
#
# Local option: `supabase start` (Docker) gives you a third “local” Postgres that
# behaves like Supabase; same Prisma migrations apply.
#
# -----------------------------------------------------------------------------
# Database (Prisma) — Supabase Postgres connection string
# -----------------------------------------------------------------------------
# Dashboard: Project Settings → Database → Connection string → URI
#
# For `prisma migrate` / `db push`, prefer the DIRECT connection (port 5432),
# not the transaction pooler, to avoid migration issues with PgBouncer.
#
# Example (direct):
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?schema=public"
#
# Optional later: a separate POOLED URL (port 6543, ?pgbouncer=true) for high-
# concurrency API runtime — only if you split Prisma datasources; not required
# to start.
# -----------------------------------------------------------------------------

DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?schema=public"
#
# Prisma Migrate (`npm run db:migrate`) should use this direct URI in packages/database/.env.
# Do not use the pooler URL there if migrate dev fails or reports shadow DB errors.

# API
PORT=3001

# API (apps/api/.env) — validate Supabase JWTs with anon key
# SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
# SUPABASE_ANON_KEY="your-anon-key"
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# ADMIN_ORIGIN="http://localhost:3000"

# Admin (apps/admin/.env) — browser-safe
# NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# NEXT_PUBLIC_API_URL="http://localhost:3001"
#
# Supabase Dashboard → Authentication → URL configuration:
# add redirect: http://localhost:3000/auth/callback (and production URL).
