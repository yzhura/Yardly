{
  "name": "yardly",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:admin": "npm run dev --workspace=admin",
    "dev:api": "npm run build --workspace=@yardly/database && npm run start:dev --workspace=api",
    "build": "npm run build --workspace=@yardly/database && npm run build --workspace=api && npm run build --workspace=admin",
    "lint": "npm run lint --workspaces --if-present",
    "db:generate": "npm run generate --workspace=@yardly/database",
    "db:generate:clean": "npm run generate:clean --workspace=@yardly/database",
    "db:migrate": "npm run db:migrate --workspace=@yardly/database",
    "db:migrate:deploy": "npm run db:migrate:deploy --workspace=@yardly/database",
    "db:migrate:status": "npm run db:migrate:status --workspace=@yardly/database",
    "db:studio": "npm run db:studio --workspace=@yardly/database"
  },
  "engines": {
    "node": ">=20"
  }
}
